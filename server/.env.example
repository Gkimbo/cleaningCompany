# ─── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT="3000"

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave blank in development to use localhost defaults)
ALLOWED_ORIGINS="https://kleanr.app,https://www.kleanr.app"

# ─── Database (production only — development uses hardcoded defaults in config/config.js) ─
DB_USER=""
DB_PASSWORD=""
DB_NAME=""
DB_HOST=""
DB_PORT="5432"

# ─── Redis (optional — required for distributed/multi-instance deployments) ────
# Format: redis://[:password@]host[:port][/db-number]
# Example: redis://default:yourpassword@your-redis-host.com:6379
REDIS_URL=""

# ─── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=""

# ─── Third-party APIs ──────────────────────────────────────────────────────────
ELEC_MAPS=""
GOOGLE_MAPS=""
API_NINJA_API_KEY=""
GOOGLE_CLOUD_VISION_API_KEY=""
PII_ENCRYPTION_KEY=""
UNSPLASH_PHOTO_ACCESS_KEY=""
UNSPLASH_PHOTO_SECRET_KEY=""

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Use test keys in development, live keys in production
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_LIVE_SECRET_KEY=""
STRIPE_LIVE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_WEBHOOK_SECRET=""

# ─── Email ─────────────────────────────────────────────────────────────────────
EMAIL_USER=""
EMAIL_PASS=""

# ─── Encryption ────────────────────────────────────────────────────────────────
TAX_ENCRYPTION_KEY=""

# ─── Error tracking ────────────────────────────────────────────────────────────
# Get from https://sentry.io — leave blank to disable
SENTRY_DSN=""

# ─── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warn | error (defaults to "info")
LOG_LEVEL="info"
